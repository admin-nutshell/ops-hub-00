{
  "name": "ops-hub",
  "version": "0.1.0",
  "description": "Ops Hub — agent-operated support platform",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.28.2",
  "scripts": {
    "dev": "node --watch dist/index.js",
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "eslint . && prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run tests/integration",
    "prepare": "node -e \"process.env.CI || require('child_process').execSync('git config core.hooksPath .githooks', {stdio:'inherit'})\""
  },
  "devDependencies": {
    "@types/node": "^20.19.9",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^2.1.8"
  }
}
