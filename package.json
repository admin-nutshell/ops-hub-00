{
  "name": "ops-hub",
  "version": "0.1.0",
  "description": "Ops Hub — agent-operated support platform",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.28.2+sha512.41872f037ad22f7348e3b1debbaf7e867cfd448f2726d9cf74c08f19507c31d2c8e7a11525b983febc2df640b5438dee6023ebb1f84ed43cc2d654d2bc326264",
  "scripts": {
    "dev": "node --watch dist/index.js",
    "build": "tsc --project tsconfig.build.json",
    "start": "node dist/index.js",
    "lint": "eslint . && prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "vitest run src/integration",
    "eval": "promptfoo eval --config 'evals/*.yaml' --no-cache",
    "eval:validate": "for f in evals/*.yaml; do promptfoo validate -c \"$f\" || exit 1; done",
    "prepare": "node -e \"process.env.CI || require('child_process').execSync('git config core.hooksPath .githooks', {stdio:'inherit'})\""
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.9.5",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "@sentry/node": "^10.66.0",
    "@supabase/supabase-js": "^2.110.7",
    "adm-zip": "0.6.0",
    "diff": "9.0.0",
    "inngest": "^4.13.0",
    "langfuse-node": "^3.38.0",
    "pg": "^8.22.0"
  }
}
